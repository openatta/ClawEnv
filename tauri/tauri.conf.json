{
  "$schema": "https://raw.githubusercontent.com/nicholasrice/application-config-schema/master/tauri-v2.json",
  "productName": "ClawEnv",
  "version": "0.1.0",
  "identifier": "com.attaspace.clawenv",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "beforeDevCommand": "npm run dev"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "ClawEnv",
        "width": 1024,
        "height": 680,
        "resizable": true,
        "fullscreen": false,
        "minWidth": 800,
        "minHeight": 560
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
